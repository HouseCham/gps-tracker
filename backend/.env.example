APP_NAME=my-app-name
DATABASE_URL=postgres://gps_user:gps_pass@localhost:5432/gps_tracker?sslmode=disable
ENABLE_INTEGRATION_TESTS=false

# Authula — required. Use a 32-byte hex string; e.g. `openssl rand -hex 32`.
AUTHULA_SECRET=my-authula-secret
# Authula — optional. Defaults to http://localhost:8080 in dev.
AUTHULA_BASE_URL=http://localhost:8080
