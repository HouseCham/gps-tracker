
PROVIDER="opencode"
GGA_PROVIDER="opencode"
FILE_PATTERNS="*.ts,*.tsx,*.js,*.jsx,*.go,*.astro"
EXCLUDE_PATTERNS="*.test.ts,*.spec.ts,*.test.tsx,*.spec.tsx,*.d.ts,*_test.go"
STRICT_MODE="true"
TIMEOUT="300"
RULES_FILE="CODE_REVIEW.md"
STRICT_MODE="true"
TIMEOUT="300"
PR_BASE_BRANCH="dev"

