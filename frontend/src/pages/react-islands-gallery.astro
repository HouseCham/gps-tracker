---
//-- Translations
import { en } from '@/i18n';
//-- Components
import MainLayout from '@/components/astro/layout/MainLayout.astro';
import GalleryIslands from '@/components/react/ui/GalleryIslands';
---

<MainLayout
    locale="en"
    translation={en}
    user={{ name: 'Gallery', role: 'Dev' }}
    active="dashboard"
    title="React Islands · Gallery"
>
    <h1>React UI Islands</h1>
    <p class="hint">Modal, Toast, and Dropdown — hydrated on the client.</p>
    <GalleryIslands client:load />
</MainLayout>

<style>
    h1 {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 4px;
    }
    .hint {
        color: var(--muted);
        font-size: 14px;
        margin-bottom: 24px;
    }
    :global(.islands) {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }
    :global(.islands__group h2) {
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--muted);
        margin-bottom: 12px;
    }
    :global(.islands__row) {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
    }
</style>
