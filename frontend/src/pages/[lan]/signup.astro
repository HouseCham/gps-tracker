---
import type { GetStaticPaths } from 'astro';
//-- Translations
import { getTranslation } from '@/i18n';
//-- types
import type { Language } from '@/types';
//-- Components
import AuthLayout from '@/components/astro/layout/AuthLayout.astro';
import { SignupForm } from '@/components/react/form';
//-- Utils
import { parseSignUpStrings } from '@/lib';

/**
 * @type {GetStaticPaths}
 */
export const getStaticPaths = (() => {
    return [{ params: { lan: 'en' } }, { params: { lan: 'es' } }];
}) satisfies GetStaticPaths;

const locale = Astro.params.lan as Language;
const translation = getTranslation(locale);
const signupStrings = parseSignUpStrings(translation.auth);
---

<AuthLayout title={`${translation.auth.signupTitle} · Open GPS`}>
    <SignupForm 
        client:load 
        strings={signupStrings} 
    />
</AuthLayout>