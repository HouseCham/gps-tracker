---
import type { GetStaticPaths } from 'astro';
//-- i18n
import { getTranslation } from '@/i18n';
//-- Types
import type { Language } from '@/types';
//-- Components
import MainLayout from '@/components/astro/layout/MainLayout.astro';
import { NoAccessNotice } from '@/components/react/features/no-access/NoAccessNotice';

/**
 * Static paths — same locales as the rest of the authenticated pages.
 */
export const getStaticPaths: GetStaticPaths = () => {
    return [{ params: { lan: 'en' } }, { params: { lan: 'es' } }];
};

// `getStaticPaths` constrains `lan` to 'en' | 'es', so the cast narrows
// the param's `string` type to the `Language` union without runtime risk.
const locale = Astro.params.lan as Language;
const translation = getTranslation(locale);
const title = `${translation.noAccess.title} · ${translation.layout.appName}`;
---

<MainLayout
    locale={locale}
    title={title}
    pageLabel={translation.noAccess.title}
    pageEyebrow={translation.layout.workspace}
>
    <NoAccessNotice
        client:load
        locale={locale}
        strings={{
            title: translation.noAccess.title,
            body: translation.noAccess.body,
            backCta: translation.noAccess.backCta,
            hint: translation.noAccess.hint,
            toastTitle: translation.toast.accessDenied.title,
            toastMessage: translation.toast.accessDenied.message,
        }}
    />
</MainLayout>
