---
import type { GetStaticPaths } from 'astro';
//-- Translations
import { getTranslation } from '@/i18n';
//-- Types
import type { Language } from '@/types';
//-- Constants
import { ADMIN_GALLERY_DEMO_STATS, DEMO_USER } from '@/constants/components';
//-- Components
import MainLayout from '@/components/astro/layout/MainLayout.astro';
import AdminStats from '@/components/admin/AdminStats.astro';
import { UserTable } from '@/components/admin/UserTable';
/**
 * @type {GetStaticPaths}
 */
export const getStaticPaths = (() => {
    return [{ params: { lan: 'en' } }, { params: { lan: 'es' } }];
}) satisfies GetStaticPaths;

const locale = Astro.params.lan as Language;
const translation = getTranslation(locale);
---

<MainLayout
    locale={locale}
    translation={translation}
    user={DEMO_USER}
    active="admin"
    showAdmin={true}
    title={`${translation.page.admin.title} · GPS Tracker`}
>
    <header class="page-header">
        <div>
            <p class="page-header__eyebrow">{translation.admin.title}</p>
            <h1 class="page-header__title">{translation.page.admin.title}</h1>
            <p class="page-header__subtitle">{translation.page.admin.subtitle}</p>
        </div>
    </header>

    <AdminStats stats={ADMIN_GALLERY_DEMO_STATS} />

    <section class="admin-users">
        <h2 class="admin-users__title">{translation.admin.users}</h2>
        <UserTable
            client:idle
            locale={locale}
            translation={translation}
        />
    </section>
</MainLayout>

<style>
    .page-header { margin-bottom: 24px; }
    .page-header__eyebrow {
        font-size: 12px; font-weight: 600; color: var(--muted);
        text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px;
    }
    .page-header__title {
        font-size: 24px; font-weight: 700; letter-spacing: -0.02em; color: var(--text);
    }
    .page-header__subtitle {
        margin: 4px 0 0;
        font-size: 14px;
        color: var(--muted);
    }
    .admin-users { margin-top: 24px; }
    .admin-users__title {
        margin: 0 0 12px;
        font-size: 14px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--muted);
    }
</style>
