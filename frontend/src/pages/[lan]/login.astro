---
import type { GetStaticPaths } from 'astro';
//-- Translations
import { getTranslation } from '@/i18n';
//-- Types
import type { Language } from '@/types';
//-- Components
import AuthLayout from '@/components/astro/layout/AuthLayout.astro';
import { LoginForm } from '@/components/react/form';
//-- Utils
import { parseLoginStrings } from '@/lib';
/**
 * @type {GetStaticPaths}
 */
export const getStaticPaths = (() => {
    return [{ params: { lan: 'en' } }, { params: { lan: 'es' } }];
}) satisfies GetStaticPaths;

const locale = Astro.params.lan as Language;
const translation = getTranslation(locale);
const loginStrings = parseLoginStrings(translation.auth);
---

<AuthLayout isLoginPage title={`${translation.auth.loginTitle} · Open GPS`}>
    <LoginForm 
        client:load 
        strings={loginStrings} 
    />
</AuthLayout>
