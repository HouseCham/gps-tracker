---
import type { GetStaticPaths } from 'astro';
//-- Translations
import { getTranslation } from '@/i18n';
//-- Types
import type { Language } from '@/types';
//-- Components
import MainLayout from '@/components/astro/layout/MainLayout.astro';
import DeviceDetail from '@/components/sections/DeviceDetail.astro';
import { DEMO_USER } from '@/constants/components';
/**
 * @type {GetStaticPaths}
 */
export const getStaticPaths = (() => {
    const ids = ['D-001', 'D-002', 'D-003', 'D-004'];
    const results: Array<{ params: { lan: string; id: string } }> = [];
    for (const lan of ['en', 'es']) {
        for (const id of ids) {
            results.push({ params: { lan, id } });
        }
    }
    return results;
}) satisfies GetStaticPaths;

const locale = Astro.params.lan as Language;
const translation = getTranslation(locale);
const deviceId = Astro.params.id!;

const deviceCatalog: Record<string, {
    id: string; name: string; status: 'online' | 'offline' | 'never-seen';
    lastSeen: string | null; battery: number; signal: number;
    uuid_firmware: string; lat: number; lng: number; createdAt: string;
}> = {
    'D-001': {
        id: 'D-001', name: 'Delivery Van #3',     status: 'online',     lastSeen: '2 min ago', battery: 78, signal: 5,
        uuid_firmware: 'a1b2c3d4-e5f6-7890-abcd-ef1234567890', lat: 19.4326, lng: -99.1332, createdAt: '2026-01-15',
    },
    'D-002': {
        id: 'D-002', name: 'Cargo Truck #12',     status: 'online',     lastSeen: '8 min ago', battery: 45, signal: 3,
        uuid_firmware: 'b2c3d4e5-f6a7-8901-bcde-f12345678901', lat: 19.4200, lng: -99.1500, createdAt: '2026-02-10',
    },
    'D-003': {
        id: 'D-003', name: 'Fleet Unit #7',       status: 'online',     lastSeen: '1 min ago', battery: 92, signal: 4,
        uuid_firmware: 'c3d4e5f6-a7b8-9012-cdef-123456789012', lat: 19.4450, lng: -99.1150, createdAt: '2026-03-05',
    },
    'D-004': {
        id: 'D-004', name: 'Service Van #2',      status: 'offline',    lastSeen: '4 hrs ago', battery: 15, signal: 0,
        uuid_firmware: 'd4e5f6a7-b8c9-0123-defa-234567890123', lat: 19.4050, lng: -99.1600, createdAt: '2026-04-22',
    },
};

const device = deviceCatalog[deviceId];

const activities = [
    { id: 'A-001', type: 'device-online' as const,     message: `${device?.name ?? 'Device'} came online`,         timestamp: '2 min ago' },
    { id: 'A-002', type: 'location-update' as const,    message: 'New position recorded',                             timestamp: '8 min ago' },
    { id: 'A-003', type: 'device-offline' as const,    message: `${device?.name ?? 'Device'} went offline`,         timestamp: '1 hr ago' },
    { id: 'A-004', type: 'alert' as const,             message: 'Battery at 15% — charging recommended',             timestamp: '3 hrs ago' },
];
---

<MainLayout
    locale={locale}
    translation={translation}
    user={DEMO_USER}
    active="devices"
    showAdmin={true}
    title={`${device?.name ?? translation.page.deviceDetail.notFound} · GPS Tracker`}
>
    {device ? (
        <DeviceDetail
            device={device}
            activities={activities}
            activityTitle={translation.section.deviceDetail.activity}
        />
    ) : (
        <header class="page-header">
            <p class="page-header__eyebrow">{translation.page.deviceDetail.title}</p>
            <h1 class="page-header__title">{translation.page.deviceDetail.notFound}</h1>
        </header>
    )}
</MainLayout>

<style>
    .page-header { margin-bottom: 24px; }
    .page-header__eyebrow {
        font-size: 12px; font-weight: 600; color: var(--muted);
        text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px;
    }
    .page-header__title {
        font-size: 24px; font-weight: 700; letter-spacing: -0.02em; color: var(--text);
    }
</style>
