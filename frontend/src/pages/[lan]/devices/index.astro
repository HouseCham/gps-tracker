---
import type { GetStaticPaths } from 'astro';
//-- Translations
import { getTranslation } from '@/i18n';
//-- Types
import type { Language } from '@/types';
//-- Constants
import { DEMO_USER } from '@/constants/components';
//-- Components
import MainLayout from '@/components/astro/layout/MainLayout.astro';
import KpiBar from '@/components/sections/KpiBar.astro';
import { DeviceTable } from '@/components/react/table/DeviceTable';
//-- Utils
import { getDemoKpiItems } from '@/lib';
/**
 * @type {GetStaticPaths}
 */
export const getStaticPaths = (() => {
    return [{ params: { lan: 'en' } }, { params: { lan: 'es' } }];
}) satisfies GetStaticPaths;

const locale = Astro.params.lan as Language;
const translation = getTranslation(locale);
const kpiItems = getDemoKpiItems(translation);
---

<MainLayout
    locale={locale}
    translation={translation}
    user={DEMO_USER}
    active="devices"
    showAdmin={true}
    title={`${translation.page.devices.title} · GPS Tracker`}
>
    <header class="page-header">
        <div>
            <p class="page-header__eyebrow">{translation.device.title}</p>
            <h1 class="page-header__title">{translation.page.devices.title}</h1>
        </div>
    </header>

    <KpiBar
        items={kpiItems}
        title={translation.section.kpiBar.title}
    />

    <section class="devices-section">
        <DeviceTable
            client:idle
            locale={locale}
            translation={translation}
        />
    </section>
</MainLayout>

<style>
    .page-header { margin-bottom: 24px; }
    .page-header__eyebrow {
        font-size: 12px; font-weight: 600; color: var(--muted);
        text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px;
    }
    .page-header__title {
        font-size: 24px; font-weight: 700; letter-spacing: -0.02em; color: var(--text);
    }
    .devices-section { margin-top: 20px; }
</style>
