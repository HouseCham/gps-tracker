---
import type { GetStaticPaths } from 'astro';
//-- Translations
import { getTranslation } from '@/i18n';
//-- Types
import type { Language } from '@/types';
//-- Components
import MainLayout from '@/components/astro/layout/MainLayout.astro';
import PageHeader from '@/components/astro/layout/PageHeader.astro';
import { ProfileView } from '@/components/react/profile';
/**
 * @type {GetStaticPaths}
 */
export const getStaticPaths = (() => {
    return [{ params: { lan: 'en' } }, { params: { lan: 'es' } }];
}) satisfies GetStaticPaths;

//* note: getStaticPaths only emits the two supported locales,
//   so the cast is exhaustive by construction.
const locale = Astro.params.lan as Language;
const translation = getTranslation(locale);
---

<MainLayout
    locale={locale}
    translation={translation}
    active="profile"
    showAdmin={true}
    title={`${translation.profile.title} · GPS Tracker`}
>
    <PageHeader
        eyebrow={translation.nav.profile}
        title={translation.profile.title}
    />

    <ProfileView
        client:load
        locale={locale}
        translation={translation}
    />
</MainLayout>