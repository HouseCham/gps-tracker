---
//-- Translations
import { getTranslation } from '@/i18n';
//-- Types
import type { Language } from '@/types';
//-- Constants
import { 
    DEMO_USER,
    SECTION_GALLERY_DEMO_ACTIVITIES,
    SECTION_GALLERY_DEMO_DEVICES,
    SECTION_GALLERY_DEMO_KPI_ITEMS
} from '@/constants/components';
//-- Components
import MainLayout from '@/components/astro/layout/MainLayout.astro';
import Dashboard from '@/components/sections/Dashboard.astro';
import type { GetStaticPaths } from 'astro';
/**
 * @type {GetStaticPaths}
 */
export const getStaticPaths = (() => {
    return [{ params: { lan: 'en' } }, { params: { lan: 'es' } }];
}) satisfies GetStaticPaths;

const locale = Astro.params.lan as Language;
const translation = getTranslation(locale);
---

<MainLayout
    locale={locale}
    translation={translation}
    user={DEMO_USER}
    active="dashboard"
    showAdmin={true}
    title="Dashboard · GPS Tracker"
>
    <header class="page-header">
        <div>
            <p class="page-header__eyebrow">{translation.section.kpiBar.title}</p>
            <h1 class="page-header__title">{translation.nav.dashboard}</h1>
        </div>
    </header>

    <Dashboard
        locale={locale}
        kpiItems={SECTION_GALLERY_DEMO_KPI_ITEMS}
        activities={SECTION_GALLERY_DEMO_ACTIVITIES}
        devices={SECTION_GALLERY_DEMO_DEVICES}
        activityTitle={translation.section.activityFeed.title}
    />
</MainLayout>

<style>
    .page-header { margin-bottom: 24px; }
    .page-header__eyebrow {
        font-size: 12px; font-weight: 600; color: var(--muted);
        text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px;
    }
    .page-header__title {
        font-size: 24px; font-weight: 700; letter-spacing: -0.02em; color: var(--text);
    }
</style>
