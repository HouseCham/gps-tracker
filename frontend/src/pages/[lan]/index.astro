---
import type { GetStaticPaths } from "astro";
import type { Language } from "@/types";
import { getTranslation } from "@/i18n";
import MainLayout from "@/components/astro/layout/MainLayout.astro";

/**
 * This page is the main entry point for the website. It will redirect to the default language (English) if no language is specified in the URL.
 * @returns {void} Redirects to the default language page.
 */
export const getStaticPaths = (() => {
    return [{ params: { lan: 'en' } }, { params: { lan: 'es' } }];
}) satisfies GetStaticPaths;

const locale = Astro.params.lan as Language;
const translation = getTranslation(locale);
const user = {
    name: "John Doe",
    role: "Admin",
    email: "john.doe@example.com",
};
---

<MainLayout
    locale={locale}
    translation={translation}
    user={user}
    active="dashboard"
    showAdmin={true}
    title="Dashboard · GPS Tracker"
>
    <header class="page-header">
        <div>
            <p class="page-header__eyebrow">Overview</p>
            <h1 class="page-header__title">Dashboard</h1>
        </div>
    </header>

    <p class="page-header__hint">
        App shell ready. Page content goes here.
    </p>

    <style>
        .page-header {
            margin-bottom: 24px;
        }
        .page-header__eyebrow {
            font-size: 12px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 4px;
        }
        .page-header__title {
            font-size: 24px;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: var(--text);
        }
        .page-header__hint {
            color: var(--muted);
            font-size: 14px;
            padding: 16px;
            background: var(--surface);
            border: 1px dashed var(--border);
            border-radius: var(--radius);
        }
    </style>
</MainLayout>
