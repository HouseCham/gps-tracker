---
import { en } from '@/i18n';
//-- Constants
import {
    SECTION_GALLERY_DEMO_ACTIVITIES,
    SECTION_GALLERY_DEMO_DEVICES,
} from '@/constants/components';
//-- Utils
import { getDemoKpiItems } from '@/lib';
//-- Styles
import '@/styles/components/gallery.css';
//-- Components
import MainLayout from '@/components/astro/layout/MainLayout.astro';
import KpiBar from '@/components/sections/KpiBar.astro';
import ActivityFeed from '@/components/sections/ActivityFeed.astro';
import Dashboard from '@/components/sections/Dashboard.astro';

const demoKpiItems = getDemoKpiItems(en);
---

<MainLayout
    locale="en"
    translation={en}
    active="dashboard"
    title="Sections & Shells · Gallery"
>
    <div class="gallery">
        <h1>Section Components & Feature Shells</h1>
        <p class="hint">KpiBar, ActivityFeed, Dashboard.</p>

        <section>
            <h2>KpiBar</h2>
            <KpiBar items={demoKpiItems} title="Overview" />
        </section>

        <section>
            <h2>ActivityFeed — populated</h2>
            <div class="feed-wrapper">
                <ActivityFeed activities={SECTION_GALLERY_DEMO_ACTIVITIES} title="Recent Activity" viewAllHref="#" />
            </div>
        </section>

        <section>
            <h2>ActivityFeed — empty</h2>
            <div class="feed-wrapper">
                <ActivityFeed activities={[]} title="Recent Activity" />
            </div>
        </section>

        <section>
            <h2>Dashboard shell</h2>
            <Dashboard
                locale="en"
                translation={en}
                kpiItems={demoKpiItems}
                activities={SECTION_GALLERY_DEMO_ACTIVITIES.slice(0, 4)}
                devices={SECTION_GALLERY_DEMO_DEVICES}
                activityTitle="Latest Activity"
            />
        </section>
    </div>
</MainLayout>

<style>
    .gallery > section { margin-bottom: 40px; }
    .feed-wrapper {
        max-width: 400px;
    }
</style>
