---
//-- Translations
import { en } from '@/i18n';
//-- Constants
import { ADMIN_GALLERY_DEMO_STATS } from '@/constants/components';
//-- Components
import MainLayout from '@/components/astro/layout/MainLayout.astro';
import AdminStats from '@/components/admin/AdminStats.astro';
//-- Styles
import '@/styles/components/gallery.css';
---

<MainLayout
    locale="en"
    translation={en}
    active="admin"
    title="Admin Components · Gallery"
>
    <div class="gallery">
        <h1>Admin Components</h1>
        <p class="hint">AdminStats — Astro domain components. (UserTable demos are commented out.)</p>

        <section>
            <h2>AdminStats</h2>
            <AdminStats stats={ADMIN_GALLERY_DEMO_STATS} />
        </section>

        <section>
            <h2>UserTable — populated</h2>
            <!-- <UserTable /> -->
        </section>

        <section>
            <h2>UserTable — empty</h2>
            <!-- <UserTable /> -->
        </section>

        <section>
            <h2>UserTable — loading</h2>
            <!-- <UserTable /> -->
        </section>
    </div>
</MainLayout>

