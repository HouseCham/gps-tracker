---
//-- Translations
import { en } from '@/i18n';
//-- Types
import { DEVICE_GALLERY_DEMO_CARD_DEVICES } from '@/constants/components';
//-- Styles
import '@/styles/components/gallery.css';
//-- Components
import MainLayout from '@/components/astro/layout/MainLayout.astro';
import DeviceCard from '@/components/astro/card/DeviceCard.astro';
import DeviceFormDemo from '@/components/react/device/DeviceFormGallery';
---

<MainLayout
    locale="en"
    translation={en}
    active="devices"
    title="Device Components · Gallery"
>
    <div class="gallery">
        <h1>Device Components</h1>
        <p class="hint">DeviceTable, DeviceCard, DeviceForm — Astro + React islands.</p>

        <section>
            <h2>DeviceTable — populated</h2>

        </section>

        <section>
            <h2>DeviceTable — empty</h2>
        </section>

        <section>
            <h2>DeviceTable — loading</h2>
        </section>

        <section>
            <h2>DeviceCard</h2>
            <div class="card-grid">
                {DEVICE_GALLERY_DEMO_CARD_DEVICES.map((d) => <DeviceCard device={d} />)}
            </div>
        </section>

        <section>
            <h2>DeviceForm (React island)</h2>
            <div class="form-surface">
                <DeviceFormDemo client:idle />
            </div>
        </section>
    </div>
</MainLayout>

<style>
    .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 12px;
    }
    .form-surface {
        max-width: 420px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
    }
</style>