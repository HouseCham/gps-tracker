---
import MainLayout from '@/components/astro/layout/MainLayout.astro';
import { en } from '@/i18n';
import MapGallery from '@/components/react/map/MapGallery';
---

<MainLayout
    locale="en"
    translation={en}
    user={{ name: 'Gallery', role: 'Dev' }}
    active="dashboard"
    title="Map Components · Gallery"
>
    <h1>Map Components</h1>
    <p class="hint">
        DeviceMap, MapMarker, MapPopover, RoutePlayer — all client:load islands.
    </p>
    <MapGallery client:load />
</MainLayout>

<style>
    h1 {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 4px;
    }
    .hint {
        color: var(--muted);
        font-size: 14px;
        margin-bottom: 20px;
    }

    :global(.map-gallery) {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    :global(.map-gallery__strip) {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
    }

    :global(.map-gallery__hint) {
        font-size: 12px;
        color: var(--muted);
        margin-left: 8px;
        font-family: var(--mono);
    }

    :global(.map-gallery__legend) {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 14px;
    }

    :global(.map-gallery__leg-item) {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 10px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 12px;
        cursor: pointer;
        transition:
            border-color var(--transition),
            background var(--transition);
        font-family: inherit;
    }
    :global(.map-gallery__leg-item:hover) {
        background: var(--surface-2);
    }
    :global(.map-gallery__leg-item.is-active) {
        border-color: var(--accent);
        background: var(--accent-soft);
    }

    :global(.map-gallery__leg-dot) {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    :global(.map-gallery__leg-dot--online) {
        background: var(--green);
    }
    :global(.map-gallery__leg-dot--offline) {
        background: var(--muted);
    }
    :global(.map-gallery__leg-dot--never-seen) {
        background: var(--amber);
    }
    :global(.map-gallery__leg-dot--unknown) {
        background: var(--muted);
        opacity: 0.5;
    }

    :global(.map-gallery__leg-name) {
        font-weight: 500;
        color: var(--text);
    }
    :global(.map-gallery__leg-status) {
        font-size: 10px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
</style>
