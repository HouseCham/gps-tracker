---
import MainLayout from '@/components/astro/layout/MainLayout.astro';
import { en } from '@/i18n';
import DeviceTable from '@/components/device/DeviceTable.astro';
import DeviceCard from '@/components/device/DeviceCard.astro';
import DeviceFormDemo from '@/components/react/device/DeviceFormGallery';

const demoDevices: Array<{
    id: string;
    name: string;
    status: 'online' | 'offline' | 'never-seen' | 'unknown';
    lastSeen: string | null;
    battery: number;
    signal: number;
}> = [
    { id: 'D-001', name: 'Delivery Van #3',   status: 'online',     lastSeen: '2 min ago',  battery: 78, signal: 5 },
    { id: 'D-002', name: 'Cargo Truck #12',   status: 'online',     lastSeen: '1 min ago',  battery: 92, signal: 4 },
    { id: 'D-003', name: 'Fleet Unit #7',     status: 'online',     lastSeen: '8 min ago',  battery: 45, signal: 3 },
    { id: 'D-004', name: 'Service Van #2',    status: 'offline',    lastSeen: '4 hrs ago',  battery: 15, signal: 0 },
    { id: 'D-005', name: 'ESP32-A4:CF:12',    status: 'never-seen', lastSeen: null,          battery: 0,  signal: 1 },
];

const demoCardDevices: Array<{
    id: string;
    name: string;
    status: 'online' | 'offline' | 'never-seen' | 'unknown';
    lastSeen: string | null;
    battery: number;
    signal: number;
    uuid_firmware: string;
}> = [
    { id: 'D-001', name: 'Delivery Van #3',   status: 'online',     lastSeen: '2 min ago',  battery: 78, signal: 5, uuid_firmware: 'a1b2c3d4-e5f6-7890-abcd-ef1234567890' },
    { id: 'D-004', name: 'Service Van #2',    status: 'offline',    lastSeen: '4 hrs ago',  battery: 15, signal: 0, uuid_firmware: 'b2c3d4e5-f6a7-8901-bcde-f12345678901' },
    { id: 'D-005', name: 'ESP32-A4:CF:12',    status: 'never-seen', lastSeen: null,          battery: 0,  signal: 1, uuid_firmware: 'c3d4e5f6-a7b8-9012-cdef-123456789012' },
];
---

<MainLayout
    locale="en"
    translation={en}
    user={{ name: 'Gallery', role: 'Dev' }}
    active="devices"
    title="Device Components · Gallery"
>
    <h1>Device Components</h1>
    <p class="hint">DeviceTable, DeviceCard, DeviceForm — Astro + React islands.</p>

    <section>
        <h2>DeviceTable — populated</h2>
        <DeviceTable devices={demoDevices} />
    </section>

    <section>
        <h2>DeviceTable — empty</h2>
        <DeviceTable devices={[]} empty />
    </section>

    <section>
        <h2>DeviceTable — loading</h2>
        <DeviceTable devices={[]} loading />
    </section>

    <section>
        <h2>DeviceCard</h2>
        <div class="card-grid">
            {demoCardDevices.map((d) => <DeviceCard device={d} />)}
        </div>
    </section>

    <section>
        <h2>DeviceForm (React island)</h2>
        <div class="form-surface">
            <DeviceFormDemo client:load />
        </div>
    </section>
</MainLayout>

<style>
    h1 { font-size: 24px; font-weight: 700; margin-bottom: 4px; }
    .hint { color: var(--muted); font-size: 14px; margin-bottom: 24px; }
    section { margin-bottom: 32px; }
    section h2 {
        font-size: 14px; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.06em; color: var(--muted); margin-bottom: 12px;
    }
    .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 12px;
    }
    .form-surface {
        max-width: 420px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
    }
</style>
