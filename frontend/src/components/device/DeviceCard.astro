---
//-- Types
import type { DeviceCardItem } from '@/types/components/device.types';
//-- Components
import StatusIndicator from '@/components/ui/StatusIndicator.astro';
import BatteryIndicator from '@/components/ui/BatteryIndicator.astro';
import SignalIndicator from '@/components/ui/SignalIndicator.astro';
/**
 * @interface Props
 * @property {DeviceCardItem} device - Device card item.
 * @property {string} href - Link href.
 * @property {string} [class] - Extra classes.
 */
interface Props {
    device: DeviceCardItem;
    href?: string;
    class?: string;
}
const {
    device,
    href = `/devices/${device.id}`,
    class: className,
} = Astro.props;
/**
 * @constant {string} classes - Class string.
 */
const classes = ['device-card', className].filter(Boolean).join(' ');
---

<article class={classes}>
    <a href={href} class="device-card__link" aria-label={`View ${device.name}`}>
        <header class="device-card__head">
            <h3 class="device-card__name">{device.name}</h3>
            <StatusIndicator status={device.status} />
        </header>
        <div class="device-card__meta">
            <span class="device-card__label">Last seen</span>
            <span class="device-card__value">{device.lastSeen ?? '—'}</span>
        </div>
        <div class="device-card__gauges">
            <div class="device-card__gauge">
                <span class="device-card__gauge-label">Battery</span>
                <BatteryIndicator level={device.battery} />
            </div>
            <div class="device-card__gauge">
                <span class="device-card__gauge-label">Signal</span>
                <SignalIndicator strength={device.signal} />
            </div>
        </div>
    </a>
</article>

<style>
    .device-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        transition:
            border-color var(--transition),
            background var(--transition);
    }
    .device-card:hover {
        border-color: var(--accent);
        background: var(--surface-2);
    }

    .device-card__link {
        display: block;
        padding: 16px;
        text-decoration: none;
        color: inherit;
    }

    .device-card__head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .device-card__name {
        margin: 0;
        font-size: 15px;
        font-weight: 600;
        color: var(--text);
        line-height: 1.2;
    }

    .device-card__meta {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        margin-bottom: 12px;
    }

    .device-card__label {
        color: var(--muted);
    }

    .device-card__value {
        font-family: var(--mono);
        color: var(--text);
    }

    .device-card__gauges {
        display: flex;
        gap: 16px;
    }

    .device-card__gauge {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .device-card__gauge-label {
        font-size: 11px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
</style>
