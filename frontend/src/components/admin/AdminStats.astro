---
import KpiCard from '@/components/ui/KpiCard.astro';
import type { AdminStatItem } from '@/types/components/admin.types';
/**
 * @interface Props
 * @property {AdminStatItem[]} stats - Admin stats items.
 * @property {string} [class] - Extra classes.
 */
interface Props {
    stats: AdminStatItem[];
    class?: string;
}

const {
    stats,
    class: className,
} = Astro.props;
/**
 * @constant {string} classes - Class string.
 */
const classes = ['admin-stats', className].filter(Boolean).join(' ');
---

<div class={classes}>
    {
        stats.map((stat) => (
            <KpiCard
                icon={stat.icon}
                value={stat.value}
                label={stat.label}
                trend={stat.trend}
                trendValue={stat.trendValue}
                variant={stat.variant}
            />
        ))
    }
</div>

<style>
    .admin-stats {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 12px;
    }
</style>
