---
//-- Constants
import { USER_TABLE_COLUMNS } from '@/constants/components';
//-- Components
import DataTable from '@/components/ui/DataTable.astro';
import { UserTableRows } from '@/components/react/UserTableRows';

/**
 * @interface Props
 * @property {string | undefined} [class] - Extra classes.
 */
interface Props {
    class?: string;
}

const { class: className } = Astro.props;
---

<DataTable columns={USER_TABLE_COLUMNS} class={className}>
    <UserTableRows client:load />
</DataTable>

<style>
    .user-table__row td {
        vertical-align: middle;
    }

    .user-table__name {
        font-weight: 500;
        color: var(--text);
    }

    .user-table__email {
        color: var(--muted);
        font-size: 12px;
    }

    .user-table__time {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--muted);
        white-space: nowrap;
    }

    .user-table__actions {
        display: inline-flex;
        gap: 4px;
    }

    td[data-align='center'] {
        text-align: center;
    }
    td[data-align='right'] {
        text-align: right;
    }
</style>
