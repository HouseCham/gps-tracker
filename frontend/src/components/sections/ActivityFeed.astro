---
//-- Types
import type { ActivityItem } from '@/types/components';
//-- Constants
import { ACTIVITY_FEED_ICON } from '@/constants/components/activityFeed';
//-- Icons
import { Activity } from '@lucide/astro';
/**
 * @interface Props
 * @property {ActivityItem[]} activities - Activity items.
 * @property {string} title - Section title.
 * @property {string | undefined} [viewAllHref] - View all link.
 * @property {string | undefined} [class] - Extra classes.
 */
interface Props {
    activities: ActivityItem[];
    title?: string;
    viewAllHref?: string;
    class?: string;
}

const {
    activities,
    title = 'Activity',
    viewAllHref,
    class: className,
} = Astro.props;

const classes = ['activity-feed', className].filter(Boolean).join(' ');
---

<section class={classes} aria-label={title}>
    <header class="activity-feed__head">
        <h2 class="activity-feed__title">{title}</h2>
        {viewAllHref && <a href={viewAllHref} class="activity-feed__view-all">View all</a>}
    </header>

    {activities.length === 0 ? (
        <p class="activity-feed__empty">No recent activity.</p>
    ) : (
        <ol class="activity-feed__list">
            {
                activities.map((item) => {
                    const Icon = ACTIVITY_FEED_ICON[item.type] ?? Activity;
                    const typeClass = `activity-feed__item--${item.type}`;
                    return (
                        <li class={['activity-feed__item', typeClass].filter(Boolean).join(' ')}>
                            <span class="activity-feed__icon" aria-hidden="true">
                                <Icon size={14} stroke-width={1.75} />
                            </span>
                            <div class="activity-feed__body">
                                <p class="activity-feed__msg">{item.message}</p>
                                <time class="activity-feed__time" datetime={item.timestamp}>
                                    {item.timestamp}
                                </time>
                            </div>
                        </li>
                    );
                })
            }
        </ol>
    )}
</section>

<style>
    .activity-feed {
        display: flex;
        flex-direction: column;
        gap: 12px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px;
    }

    .activity-feed__head {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .activity-feed__title {
        margin: 0;
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--muted);
    }

    .activity-feed__view-all {
        font-size: 12px;
        color: var(--accent);
        text-decoration: none;
        font-weight: 500;
    }
    .activity-feed__view-all:hover {
        text-decoration: underline;
    }

    .activity-feed__list {
        display: flex;
        flex-direction: column;
        gap: 0;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .activity-feed__item {
        display: flex;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid var(--border);
    }
    .activity-feed__item:last-child {
        border-bottom: 0;
        padding-bottom: 0;
    }
    .activity-feed__item:first-child {
        padding-top: 0;
    }

    .activity-feed__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        flex-shrink: 0;
        border-radius: 50%;
        background: var(--surface-2);
        color: var(--muted);
        margin-top: 2px;
    }

    .activity-feed__item--device-online .activity-feed__icon {
        background: var(--green-soft);
        color: var(--green);
    }
    .activity-feed__item--device-offline .activity-feed__icon {
        background: var(--red-soft);
        color: var(--red);
    }
    .activity-feed__item--alert .activity-feed__icon {
        background: var(--amber-soft);
        color: var(--amber);
    }
    .activity-feed__item--device-added .activity-feed__icon {
        background: var(--accent-soft);
        color: var(--accent);
    }
    .activity-feed__item--user-login .activity-feed__icon {
        background: var(--green-soft);
        color: var(--green);
    }
    .activity-feed__item--role-change .activity-feed__icon {
        background: var(--accent-soft);
        color: var(--accent);
    }

    .activity-feed__body {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
        flex: 1;
    }

    .activity-feed__msg {
        margin: 0;
        font-size: 13px;
        color: var(--text);
        line-height: 1.4;
    }

    .activity-feed__time {
        font-size: 11px;
        color: var(--muted);
        font-family: var(--mono);
    }

    .activity-feed__empty {
        margin: 0;
        font-size: 13px;
        color: var(--muted);
        text-align: center;
        padding: 24px 0;
    }
</style>
