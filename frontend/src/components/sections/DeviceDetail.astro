---
//- Types
import type { DeviceDetailData, ActivityItem } from '@/types/components';
//-- Translations
import { getTranslation } from '@/i18n';
import type { Language } from '@/types';
//-- Components
import ActivityFeed from '@/components/sections/ActivityFeed.astro';
import BatteryIndicator from '@/components/ui/BatteryIndicator.astro';
import SignalIndicator from '@/components/ui/SignalIndicator.astro';
import { Badge, StatusIndicator } from '@/components/ui';
/**
 * @interface Props
 * @property {DeviceDetailData} device - Device detail data.
 * @property {ActivityItem[]} activities - Activity feed items.
 * @property {string | undefined} [activityTitle] - Activity feed title.
 * @property {string | undefined} [class] - Extra classes.
 */
interface Props {
    device: DeviceDetailData;
    activities: ActivityItem[];
    activityTitle?: string;
    class?: string;
    locale?: Language;
}

const {
    device,
    activities,
    activityTitle,
    class: className,
    locale = 'en',
} = Astro.props;

const translation = getTranslation(locale);
const classes = ['device-detail', className].filter(Boolean).join(' ');

const deviceStatus = device.status === 'online' ? 'online' : 'offline';
const statusLabel = deviceStatus === 'online' ? translation.device.online : translation.device.offline;
---

<article class={classes}>
    <header class="device-detail__head">
        <div class="device-detail__head-left">
            <h1 class="device-detail__name">{device.name}</h1>
            <StatusIndicator status={device.status} />
        </div>
        <Badge variant="accent" size="sm" label={device.id} />
    </header>

    <div class="device-detail__body">
        <div class="device-detail__main">
            <section class="device-detail__card">
                <h2 class="device-detail__card-title">Overview</h2>
                <dl class="device-detail__grid">
                    <div class="device-detail__field">
                        <dt class="device-detail__label">Status</dt>
                        <dd class="device-detail__value">
                            <StatusIndicator status={deviceStatus} label={statusLabel} />
                        </dd>
                    </div>
                    <div class="device-detail__field">
                        <dt class="device-detail__label">Last seen</dt>
                        <dd class="device-detail__value device-detail__value--mono">
                            {device.lastSeen ?? '—'}
                        </dd>
                    </div>
                    <div class="device-detail__field">
                        <dt class="device-detail__label">Battery</dt>
                        <dd class="device-detail__value">
                            <BatteryIndicator level={device.battery} />
                        </dd>
                    </div>
                    <div class="device-detail__field">
                        <dt class="device-detail__label">Signal</dt>
                        <dd class="device-detail__value">
                            <SignalIndicator strength={device.signal} />
                        </dd>
                    </div>
                    <div class="device-detail__field">
                        <dt class="device-detail__label">Coordinates</dt>
                        <dd class="device-detail__value device-detail__value--mono">
                            {device.lat.toFixed(4)}, {device.lng.toFixed(4)}
                        </dd>
                    </div>
                </dl>
            </section>

            <section class="device-detail__card">
                <h2 class="device-detail__card-title">Firmware</h2>
                <dl class="device-detail__grid">
                    <div class="device-detail__field">
                        <dt class="device-detail__label">UUID</dt>
                        <dd class="device-detail__value device-detail__value--mono device-detail__value--sm">
                            {device.uuid_firmware}
                        </dd>
                    </div>
                    <div class="device-detail__field">
                        <dt class="device-detail__label">Created</dt>
                        <dd class="device-detail__value device-detail__value--mono">
                            {device.createdAt}
                        </dd>
                    </div>
                </dl>
            </section>

            <section class="device-detail__card device-detail__map">
                <h2 class="device-detail__card-title">Map</h2>
                <div class="device-detail__map-placeholder" aria-label="Map showing device location">
                    <span class="device-detail__map-coords">
                        {device.lat.toFixed(4)}, {device.lng.toFixed(4)}
                    </span>
                </div>
            </section>
        </div>

        <aside class="device-detail__aside">
            <ActivityFeed
                activities={activities}
                title={activityTitle}
            />
        </aside>
    </div>
</article>

<style>
    .device-detail {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .device-detail__head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .device-detail__head-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .device-detail__name {
        margin: 0;
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 600;
        color: var(--text);
        letter-spacing: 0;
        line-height: 1.2;
    }

    .device-detail__body {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 24px;
        align-items: start;
    }

    .device-detail__main {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .device-detail__card {
        background: var(--surface);
        border: none;
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        padding: 20px;
    }

    .device-detail__card-title {
        margin: 0 0 16px;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--muted);
    }

    .device-detail__grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        margin: 0;
    }

    .device-detail__field {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .device-detail__label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
    }

    .device-detail__value {
        margin: 0;
        font-size: 14px;
        color: var(--text);
    }

    .device-detail__value--mono {
        font-family: var(--mono);
        font-size: 13px;
    }

    .device-detail__value--sm {
        font-size: 12px;
        word-break: break-all;
    }

    .device-detail__aside {
        position: sticky;
        top: 20px;
    }

    .device-detail__map-placeholder {
        width: 100%;
        height: 200px;
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .device-detail__map-coords {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--muted);
    }

    @media (max-width: 1023.98px) {
        .device-detail__body {
            grid-template-columns: 1fr;
        }
        .device-detail__aside {
            position: static;
        }
        .device-detail__grid {
            grid-template-columns: 1fr;
        }
    }
</style>
