---
//-- Types
import type { KpiBarItem } from '@/types/components/section.types';
//-- Components
import KpiCard from '@/components/ui/KpiCard.astro';
/**
 * @interface Props
 * @property {KpiBarItem[]} items - KPI bar items.
 * @property {string | undefined} [title] - Section title.
 * @property {string | undefined} [class] - Extra classes.
 */
interface Props {
    items: KpiBarItem[];
    title?: string;
    class?: string;
}

const {
    items,
    title,
    class: className,
} = Astro.props;

const classes = ['kpi-bar', className].filter(Boolean).join(' ');
---

<section class={classes} aria-label={title ?? 'Key metrics'}>
    {title && <h2 class="kpi-bar__title">{title}</h2>}
    <div class="kpi-bar__grid">
        {items.map((item) => (
            <KpiCard
                icon={item.icon}
                value={item.value}
                label={item.label}
                trend={item.trend}
                trendValue={item.trendValue}
                variant={item.variant}
            />
        ))}
    </div>
</section>

<style>
    .kpi-bar {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .kpi-bar__title {
        margin: 0;
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--muted);
    }

    .kpi-bar__grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 12px;
    }

    @media (max-width: 767.98px) {
        .kpi-bar__grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>
