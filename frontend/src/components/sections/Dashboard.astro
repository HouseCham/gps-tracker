---
import type { Translation } from '@/i18n';
import type { KpiBarItem, ActivityItem, DeviceTableItem } from '@/types/components';
import type { Language } from '@/types';
import KpiBar from '@/components/sections/KpiBar.astro';
import ActivityFeed from '@/components/sections/ActivityFeed.astro';
import DeviceTable from '@/components/device/DeviceTable.astro';

interface Props {
    locale: Language;
    translation: Translation;
    kpiItems: KpiBarItem[];
    activities: ActivityItem[];
    devices: DeviceTableItem[];
    devicesLoading?: boolean;
    devicesEmpty?: boolean;
    activityTitle?: string;
    viewAllHref?: string;
    class?: string;
}

const {
    locale,
    translation,
    kpiItems,
    activities,
    devices,
    devicesLoading = false,
    devicesEmpty = false,
    activityTitle,
    viewAllHref,
    class: className,
} = Astro.props;

const classes = ['dashboard', className].filter(Boolean).join(' ');
---

<div class={classes}>
    <KpiBar items={kpiItems} title={translation.section.kpiBar.title} />

    <div class="dashboard__main">
        <div class="dashboard__feed">
            <ActivityFeed
                activities={activities}
                title={activityTitle}
                viewAllHref={viewAllHref}
            />
        </div>
        <div class="dashboard__table">
            <DeviceTable
                locale={locale}
                translation={translation}
                devices={devices}
                loading={devicesLoading}
                empty={devicesEmpty}
            />
        </div>
    </div>
</div>

<style>
    .dashboard {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .dashboard__main {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 20px;
        align-items: start;
    }

    .dashboard__feed {
        position: sticky;
        top: 20px;
    }

    @media (max-width: 1023.98px) {
        .dashboard__main {
            grid-template-columns: 1fr;
        }
        .dashboard__feed {
            position: static;
            order: 1;
        }
        .dashboard__table {
            order: 0;
        }
    }
</style>
