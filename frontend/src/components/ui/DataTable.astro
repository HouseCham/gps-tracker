---
import type { DataTableColumn } from '@/types/components/ui';

/**
 * @interface Props
 * @property {string | undefined} [caption] - Table caption.
 * @property {DataTableColumn[]} columns - Table columns.
 * @property {string | undefined} [class] - Extra classes.
 */
interface Props {
    caption?: string;
    columns: DataTableColumn[];
    class?: string;
}

const {
    caption,
    columns,
    class: className,
} = Astro.props;

const rootClasses = [
    'data-table',
    className,
]
    .filter(Boolean)
    .join(' ');
---

<div class="data-table__scroll">
    <table class={rootClasses}>
        {caption && <caption class="data-table__caption">{caption}</caption>}
        <thead>
            <tr>
                {
                    columns.map((col) => {
                        const align = col.align ?? 'left';
                        return (
                            <th
                                scope="col"
                                style={col.width ? `width: ${col.width}` : undefined}
                                class:list={[
                                    'data-table__head',
                                    col.sortable && 'is-sortable',
                                    `is-align-${align}`,
                                ]}
                                aria-sort={col.sortable ? 'none' : undefined}
                            >
                                {col.sortable ? (
                                    <button class="data-table__sort" type="button">
                                        <span>{col.label}</span>
                                        <svg
                                            class="data-table__sort-icon"
                                            width="10"
                                            height="10"
                                            viewBox="0 0 10 10"
                                            fill="none"
                                            aria-hidden="true"
                                        >
                                            <path d="M5 2l3 4H2l3-4z" fill="currentColor" />
                                        </svg>
                                    </button>
                                ) : (
                                    col.label
                                )}
                            </th>
                        );
                    })
                }
            </tr>
        </thead>
        <tbody>
            <slot />
        </tbody>
    </table>
</div>

<style>
    .data-table__scroll {
        background: var(--surface);
        border: none;
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        overflow: auto;
        max-height: 100%;
    }

    .data-table__caption {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        padding: 0;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    .data-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 13px;
    }

    .data-table thead th {
        position: sticky;
        top: 0;
        z-index: 1;
        background: var(--surface-2);
        color: var(--muted);
        font-weight: 600;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        text-align: left;
        padding: 10px 16px;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
    }

    .data-table__head.is-sortable {
        padding: 0;
    }

    .data-table__sort {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        width: 100%;
        height: 100%;
        padding: 10px 16px;
        background: none;
        border: 0;
        color: inherit;
        font: inherit;
        text-transform: inherit;
        letter-spacing: inherit;
        text-align: left;
        cursor: pointer;
        transition: color var(--transition);
    }

    .data-table__sort:hover {
        color: var(--text);
    }

    .data-table__sort-icon {
        opacity: 0.4;
        transition: transform var(--transition), opacity var(--transition);
    }

    .data-table__head.is-sorted-asc {
        color: var(--text);
    }
    .data-table__head.is-sorted-asc .data-table__sort-icon {
        opacity: 1;
        transform: rotate(0deg);
    }
    .data-table__head.is-sorted-desc {
        color: var(--text);
    }
    .data-table__head.is-sorted-desc .data-table__sort-icon {
        opacity: 1;
        transform: rotate(180deg);
    }

    .data-table tbody td.data-table__cell {
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        color: var(--text);
        vertical-align: middle;
    }
    .data-table tbody tr:last-child td {
        border-bottom: 0;
    }
    .data-table__row:hover td {
        background: var(--bg);
    }

    .data-table .is-align-right {
        text-align: right;
    }
    .data-table .is-align-center {
        text-align: center;
    }

    /* Loading skeleton */
    .data-table__skeleton {
        display: block;
        height: 12px;
        width: 100%;
        border-radius: 4px;
        background: linear-gradient(
            90deg,
            var(--surface-2) 0%,
            var(--border) 50%,
            var(--surface-2) 100%
        );
        background-size: 200% 100%;
        animation: dt-shimmer 1.4s linear infinite;
    }
    .data-table__skeleton--name {
        width: 60%;
    }
    .data-table__skeleton--email {
        width: 80%;
    }
    .data-table__skeleton--status {
        width: 64px;
        height: 20px;
        border-radius: var(--radius-pill);
    }
    .data-table__skeleton--role,
    .data-table__skeleton--actions,
    .data-table__skeleton--time {
        width: 50%;
    }

    @keyframes dt-shimmer {
        0% {
            background-position: 200% 0;
        }
        100% {
            background-position: -200% 0;
        }
    }

    /* Empty state */
    .data-table__empty {
        text-align: center;
        padding: 48px 16px;
        color: var(--muted);
    }
    .data-table__empty-row td {
        border-bottom: 0;
    }
    .data-table__empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }
    .data-table__empty-icon {
        width: 40px;
        height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--surface-2);
        color: var(--muted);
        border-radius: 50%;
        margin-bottom: 4px;
    }
    .data-table__empty-title {
        color: var(--text);
        font-weight: 600;
        font-size: 14px;
    }
    .data-table__empty-msg {
        font-size: 13px;
        max-width: 36ch;
    }

    @media (max-width: 767.98px) {
        .data-table thead th,
        .data-table__sort,
        .data-table tbody td.data-table__cell {
            padding: 10px 12px;
        }
        .data-table__scroll {
            border-radius: var(--radius-sm);
        }
    }
</style>
