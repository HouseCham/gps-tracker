---
/**
 * @interface Props
 * @property {number} strength - Signal strength (0–5).
 * @property {string | undefined} [class] - Extra classes.
 */
interface Props {
    strength: number;
    class?: string;
}

const { strength, class: className } = Astro.props;
const clamped = Math.max(0, Math.min(5, Math.round(strength)));
const ariaLabel = `Signal strength ${clamped} of 5`;
const classes = ['signal', 'signal-indicator', className].filter(Boolean).join(' ');
---

<div
    class={classes}
    role="meter"
    aria-label={ariaLabel}
    aria-valuenow={clamped}
    aria-valuemin="0"
    aria-valuemax="5"
>
    {
        Array.from({ length: 5 }).map((_, i) => (
            <span class:list={['signal-bar', i < clamped && 'active']} aria-hidden="true" />
        ))
    }
</div>

<style>
    .signal-indicator {
        gap: 2px;
    }
</style>
