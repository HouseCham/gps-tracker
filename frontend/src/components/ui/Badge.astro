---
import type { BadgeSize, BadgeVariant } from '@/types/components/ui';
/**
 * @interface Props
 * @property {BadgeVariant} [variant='default'] - Badge variant.
 * @property {BadgeSize} [size='md'] - Badge size.
 * @property {string} [label] - Badge label.
 * @property {string | undefined} [class] - Extra classes.
 */
interface Props {
    variant?: BadgeVariant;
    size?: BadgeSize;
    label?: string;
    class?: string;
}

const {
    variant = 'default',
    size = 'md',
    label,
    class: className,
} = Astro.props;

const classes = [
    'badge',
    'chip',
    variant === 'success' && 'green',
    variant === 'warning' && 'amber',
    variant === 'danger' && 'red',
    variant === 'accent' && 'indigo',
    size === 'sm' && 'badge--sm',
    className,
]
    .filter(Boolean)
    .join(' ');
---

<span class={classes}>{label ?? <slot />}</span>

<style>
    .badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: auto;
        min-height: 20px;
        padding: 2px 8px;
        font-weight: 500;
    }
    .badge--sm {
        height: 18px;
        padding: 1px 6px;
        font-size: 10px;
    }
</style>
