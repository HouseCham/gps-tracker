---
import type { KpiIcon, KpiTrend, KpiVariant } from '@/types/components/ui';
import {
    TrendingUp,
    TrendingDown,
    Minus,
    Cpu,
    Activity,
    Wifi,
    WifiOff,
    TriangleAlert,
    Users,
    MapPin,
    Battery,
    Signal,
} from '@lucide/astro';

const ICON_MAP = {
    cpu: Cpu,
    activity: Activity,
    wifi: Wifi,
    'wifi-off': WifiOff,
    alert: TriangleAlert,
    users: Users,
    'map-pin': MapPin,
    battery: Battery,
    signal: Signal,
} as const;
/**
 * @interface Props
 * @property {KpiIcon | undefined} [icon] - KPI icon.
 * @property {string | number} value - KPI value.
 * @property {string} label - KPI label.
 * @property {KpiTrend | undefined} [trend] - KPI trend.
 * @property {string | undefined} [trendValue] - KPI trend value.
 * @property {KpiVariant} [variant='neutral'] - KPI variant.
 * @property {string | undefined} [href] - KPI href.
 * @property {string | undefined} [class] - Extra classes.
 */
interface Props {
    icon?: KpiIcon;
    value: string | number;
    label: string;
    trend?: KpiTrend;
    trendValue?: string;
    variant?: KpiVariant;
    href?: string;
    class?: string;
}

const {
    icon,
    value,
    label,
    trend,
    trendValue,
    variant = 'neutral',
    href,
    class: className,
} = Astro.props;

const Icon = icon ? ICON_MAP[icon] : undefined;
const TrendIcon =
    trend === 'up' ? TrendingUp : trend === 'down' ? TrendingDown : Minus;
const classes = ['kpi-card', `kpi-card--${variant}`, className]
    .filter(Boolean)
    .join(' ');
const trendClasses = ['kpi-card__trend', trend && `kpi-card__trend--${trend}`]
    .filter(Boolean)
    .join(' ');
---

{
    href ? (
        <a href={href} class={classes}>
            {Icon && (
                <span class="kpi-card__icon" aria-hidden="true">
                    <Icon size={16} stroke-width={1.75} />
                </span>
            )}
            <div class="kpi-card__body">
                <div class="kpi-card__value">{value}</div>
                <div class="kpi-card__label">{label}</div>
                {trend && trendValue && (
                    <div class={trendClasses}>
                        <TrendIcon size={12} stroke-width={2} />
                        <span>{trendValue}</span>
                    </div>
                )}
            </div>
        </a>
    ) : (
        <div class={classes}>
            {Icon && (
                <span class="kpi-card__icon" aria-hidden="true">
                    <Icon size={16} stroke-width={1.75} />
                </span>
            )}
            <div class="kpi-card__body">
                <div class="kpi-card__value">{value}</div>
                <div class="kpi-card__label">{label}</div>
                {trend && trendValue && (
                    <div class={trendClasses}>
                        <TrendIcon size={12} stroke-width={2} />
                        <span>{trendValue}</span>
                    </div>
                )}
            </div>
        </div>
    )
}

<style>
    .kpi-card {
        display: flex;
        gap: 12px;
        padding: 16px;
        background: var(--surface);
        border: none;
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        text-decoration: none;
        color: inherit;
        transition:
            box-shadow var(--transition),
            background var(--transition);
    }

    a.kpi-card:hover {
        box-shadow: var(--shadow-lg);
        background: var(--surface-2);
    }

    .kpi-card__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        flex-shrink: 0;
        border-radius: var(--radius-sm);
        background: var(--surface-2);
        color: var(--text);
    }

    .kpi-card--success .kpi-card__icon {
        background: var(--green-soft);
        color: var(--green);
    }
    .kpi-card--warning .kpi-card__icon {
        background: var(--amber-soft);
        color: var(--amber);
    }
    .kpi-card--danger .kpi-card__icon {
        background: var(--red-soft);
        color: var(--red);
    }
    .kpi-card--accent .kpi-card__icon {
        background: var(--accent-soft);
        color: var(--accent);
    }

    .kpi-card__body {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
        flex: 1;
    }

    .kpi-card__value {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 600;
        letter-spacing: 0;
        line-height: 1.15;
        color: var(--text);
    }

    .kpi-card__label {
        font-size: 12px;
        color: var(--muted);
        font-weight: 500;
    }

    .kpi-card__trend {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        font-weight: 500;
        margin-top: 4px;
    }

    .kpi-card__trend--up {
        color: var(--green);
    }
    .kpi-card__trend--down {
        color: var(--red);
    }
    .kpi-card__trend--flat {
        color: var(--muted);
    }
</style>
