---
/**
 * @interface Props
 * @property {number} level - Battery level (0–100).
 * @property {boolean} [showIcon=false] - Show battery icon.
 * @property {string | undefined} [class] - Extra classes.
 */
interface Props {
    level: number;
    showIcon?: boolean;
    class?: string;
}

const { level, showIcon = false, class: className } = Astro.props;

const clamped = Math.max(0, Math.min(100, Math.round(level)));
const colorClass = clamped === 0 ? 'red battery-bar--empty' : clamped < 20 ? 'red' : clamped <= 50 ? 'amber' : 'green';
const ariaLabel = `Battery level ${clamped}%`;
const classes = ['battery', 'battery-indicator', className].filter(Boolean).join(' ');
---

<div
    class={classes}
    role="meter"
    aria-label={ariaLabel}
    aria-valuenow={clamped}
    aria-valuemin="0"
    aria-valuemax="100"
>
    <div class="battery-bar" aria-hidden="true">
        <div class={colorClass} style={`width: ${clamped}%`}></div>
    </div>
    <span class="battery-text">{clamped}%</span>
    {showIcon && <span class="battery-indicator__label">Battery</span>}
</div>

<style>
    .battery-indicator {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .battery-indicator__label {
        font-size: 12px;
        color: var(--muted);
        font-weight: 500;
    }

    .battery-bar--empty {
        animation: battery-flash 1.4s ease-in-out infinite;
    }

    @keyframes battery-flash {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0.35;
        }
    }
</style>
