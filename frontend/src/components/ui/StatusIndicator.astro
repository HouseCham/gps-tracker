---
import type { StatusVariant } from '@/types/components/ui';

/**
 * @interface Props
 * @property {StatusVariant} [status='unknown'] - Status variant.
 * @property {string} [label] - Status label.
 * @property {string | undefined} [class] - Extra classes.
 */
interface Props {
    status?: StatusVariant;
    label?: string;
    class?: string;
}

const { status = 'unknown', label, class: className } = Astro.props;

const defaultLabel: Record<StatusVariant, string> = {
    online: 'Online',
    offline: 'Offline',
    'never-seen': 'Never seen',
    unknown: 'Unknown',
};

const dotColor: Record<StatusVariant, string> = {
    online: 'green',
    offline: '',
    'never-seen': 'amber',
    unknown: '',
};

const textLabel = label ?? defaultLabel[status];

const classes = ['status-indicator', className].filter(Boolean).join(' ');
---

<span class={classes} data-status={status} role="status" aria-label={`${textLabel}`}>
    <span
        class:list={['status-indicator__dot', 'status-dot', dotColor[status], status === 'online' && 'pulse']}
        aria-hidden="true"
    ></span>
    <span class="status-indicator__label">{textLabel}</span>
</span>

<style>
    .status-indicator {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        font-weight: 500;
        line-height: 1;
    }

    .status-indicator__dot {
        width: 8px;
        height: 8px;
    }

    .status-indicator[data-status='offline'] .status-indicator__dot,
    .status-indicator[data-status='unknown'] .status-indicator__dot {
        background: var(--muted);
        box-shadow: none;
    }

    .status-indicator[data-status='never-seen'] .status-indicator__dot {
        background: var(--amber);
        box-shadow: 0 0 0 3px var(--amber-soft);
    }

    .status-indicator__label {
        color: var(--text);
    }
</style>
