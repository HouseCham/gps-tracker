---
import type { ButtonSize, ButtonVariant } from '@/types/components/ui';

/**
 * @interface Props
 * @property {ButtonVariant} [variant='primary'] - Button variant.
 * @property {ButtonSize} [size='md'] - Button size.
 * @property {boolean} [disabled=false] - Disable button.
 * @property {boolean} [loading=false] - Show loading indicator.
 * @property {'button' | 'submit' | 'reset'} [type='button'] - Button type.
 * @property {boolean} [block=false] - Make button block width.
 * @property {string | undefined} [class] - Extra classes.
 */
interface Props {
    variant?: ButtonVariant;
    size?: ButtonSize;
    disabled?: boolean;
    loading?: boolean;
    type?: 'button' | 'submit' | 'reset';
    block?: boolean;
    id?: string;
    name?: string;
    value?: string;
    'aria-label'?: string;
    class?: string;
}

const {
    variant = 'primary',
    size = 'md',
    disabled = false,
    loading = false,
    type = 'button',
    block = false,
    id,
    name,
    value,
    class: className,
    'aria-label': ariaLabel,
} = Astro.props;

const classes = [
    'btn',
    `btn-${variant}`,
    size === 'sm' && 'btn-sm',
    size === 'lg' && 'btn-lg',
    block && 'btn-block',
    loading && 'loading',
    className,
]
    .filter(Boolean)
    .join(' ');
---

<button
    id={id}
    name={name}
    value={value}
    type={type}
    class={classes}
    disabled={disabled || loading || undefined}
    aria-busy={loading || undefined}
    aria-label={ariaLabel}
>
    <slot />
</button>
