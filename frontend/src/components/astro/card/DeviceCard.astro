---
//-- Types
import type { DeviceCardItem } from '@/types/components/device.types';
import type { Language } from '@/types';
//-- Translations
import { getTranslation } from '@/i18n';
//-- Components
import BatteryIndicator from '@/components/ui/BatteryIndicator.astro';
import SignalIndicator from '@/components/ui/SignalIndicator.astro';
import { StatusIndicator } from '@/components/ui';
/**
 * @interface Props
 * @property {DeviceCardItem} device - Device card item.
 * @property {string} href - Link href.
 * @property {string} [class] - Extra classes.
 * @property {Language} [locale] - Locale for translations.
 */
interface Props {
    device: DeviceCardItem;
    href?: string;
    class?: string;
    locale?: Language;
}
const {
    device,
    href = `/devices/${device.id}`,
    class: className,
    locale = 'en',
} = Astro.props;

const translation = getTranslation(locale);
const classes = ['device-card', className].filter(Boolean).join(' ');

const deviceStatus = device.status === 'online' ? 'online' : 'offline';
const statusLabel = deviceStatus === 'online' ? translation.device.online : translation.device.offline;
---

<article class={classes}>
    <a href={href} class="device-card__link" aria-label={`View ${device.name}`}>
        <header class="device-card__head">
            <h3 class="device-card__name">{device.name}</h3>
            <StatusIndicator status={deviceStatus} label={statusLabel} />
        </header>
        <div class="device-card__meta">
            <span class="device-card__label">Last seen</span>
            <span class="device-card__value">{device.lastSeen ?? '—'}</span>
        </div>
        <div class="device-card__gauges">
            <div class="device-card__gauge">
                <span class="device-card__gauge-label">Battery</span>
                <BatteryIndicator level={device.battery} />
            </div>
            <div class="device-card__gauge">
                <span class="device-card__gauge-label">Signal</span>
                <SignalIndicator strength={device.signal} />
            </div>
        </div>
    </a>
</article>

<style>
    .device-card {
        background: var(--surface);
        border: none;
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        transition:
            box-shadow var(--transition),
            background var(--transition);
    }
    .device-card:hover {
        box-shadow: var(--shadow-lg);
        background: var(--surface-2);
    }

    .device-card__link {
        display: block;
        padding: 16px;
        text-decoration: none;
        color: inherit;
    }

    .device-card__head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .device-card__name {
        margin: 0;
        font-family: var(--font-display);
        font-size: 16px;
        font-weight: 600;
        color: var(--text);
        line-height: 1.1;
        letter-spacing: 0;
    }

    .device-card__meta {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        margin-bottom: 12px;
    }

    .device-card__label {
        color: var(--muted);
    }

    .device-card__value {
        font-family: var(--mono);
        color: var(--text);
    }

    .device-card__gauges {
        display: flex;
        gap: 16px;
    }

    .device-card__gauge {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .device-card__gauge-label {
        font-size: 11px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
</style>
