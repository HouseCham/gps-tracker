---
import ThemeToggle from '@/components/react/ui/ThemeToggle';
import LanguageToggle from '@/components/react/ui/LanguageToggle';
import type { Language } from '@/types';
/**
 * @interface Props
 * @property {Language} locale - Current locale code ('en' | 'es').
 */
interface Props {
    locale: Language;
}
const { locale } = Astro.props;
---

<header class="app-shell__toolbar">
    <div class="app-shell__toolbar-actions">
        <LanguageToggle client:load locale={locale} />
        <ThemeToggle client:load />
    </div>
</header>
<style>
    .app-shell__toolbar {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        height: 40px;
        padding-bottom: 16px;
        margin-bottom: 16px;
        border-bottom: 1px solid var(--border);
    }
    .app-shell__toolbar-actions {
        display: flex;
        gap: 4px;
    }
</style>
