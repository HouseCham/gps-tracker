---
import '@/styles/global.css';
import '@/styles/sidebar.css';
import '@/styles/topbar.css';
//-- i18n
import { getTranslation } from '@/i18n';
//-- Types
import type { Language } from '@/types';
//-- Components
import AppShell from '@/components/astro/layout/AppShell.astro';
import {
    AuthProvider,
    OnlyAdminRoute,
    ProtectedRoute,
} from '@/components/react/auth';
import { ToastProvider } from '@/components/react/ui';
/**
 * @interface Props
 * @property {Language} [locale='en'] - Current locale code.
 * @property {string | undefined} [title] - Page title.
 * @property {string} pageLabel - Page title.
 * @property {string | undefined} [pageEyebrow] - Page eyebrow.
 * @property {string | undefined} [class] - Extra classes.
 * @property {boolean} [onlyAdmin] - Marks the page as admin-only.
 */
interface Props {
    locale?: Language;
    title?: string;
    pageLabel: string;
    pageEyebrow?: string;
    class?: string;
    onlyAdmin?: boolean;
}

const {
    locale = 'en',
    title = 'Open GPS',
    pageLabel,
    pageEyebrow,
    class: className,
    onlyAdmin = false,
} = Astro.props;
const t = getTranslation(locale);
const currentPath = Astro.url.pathname;
---

<html lang={locale}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta
            name="description"
            content={`${pageLabel} · ${t.layout.appName}`}
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <script>
            import '@/scripts/theme-init.js';
        </script>
    </head>
    <body>
        <ToastProvider client:idle />
        <AuthProvider client:idle>
            <ProtectedRoute client:load>
                {
                    onlyAdmin ? (
                        <OnlyAdminRoute client:load locale={locale}>
                            <AppShell
                                locale={locale}
                                pageLabel={pageLabel}
                                pageEyebrow={pageEyebrow}
                                class={className}
                                nav={t.nav}
                                layout={t.layout}
                                currentPath={currentPath}
                            >
                                <slot />
                            </AppShell>
                        </OnlyAdminRoute>
                    ) : (
                        <AppShell
                            locale={locale}
                            pageLabel={pageLabel}
                            pageEyebrow={pageEyebrow}
                            class={className}
                            nav={t.nav}
                            layout={t.layout}
                            currentPath={currentPath}
                        >
                            <slot />
                        </AppShell>
                    )
                }
            </ProtectedRoute>
        </AuthProvider>
    </body>
</html>
