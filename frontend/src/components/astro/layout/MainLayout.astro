---
import '@/styles/global.css';
import '@/styles/layout/main-layout.css';
//-- Types
import type { Translation } from '@/i18n';
import type { Language } from '@/types';
import type { SidebarNavItem, SidebarUser } from '@/types/layout';
//-- Components
import Sidebar from '@/components/astro/Sidebar.astro';
import TabBar from '@/components/astro/TabBar.astro';
import Toolbar from '@/components/astro/Toolbar.astro';
import {
    AuthProvider,
    ProtectedRoute
} from '@/components/react/auth';

/**
 * @interface Props
 * @property {Language} locale - Current locale code ('en' | 'es').
 * @property {Translation} translation - Translation bundle (en/es) used for nav labels.
 * @property {SidebarUser} [user] - Current user for the sidebar footer card.
 * @property {SidebarNavItem} [active] - Active nav item, drives the .active highlight and aria-current.
 * @property {boolean} [showAdmin] - Whether to surface the Admin nav item (super_admin only).
 * @property {string} [title] - Document title override; falls back to "GPS Tracker".
 */
interface Props {
    locale: Language;
    translation: Translation;
    user?: SidebarUser;
    active?: SidebarNavItem;
    showAdmin?: boolean;
    title?: string;
}

const {
    locale = 'en',
    translation,
    user,
    active = 'dashboard',
    showAdmin = false,
    title = 'GPS Tracker',
} = Astro.props;
---

<html lang={locale}>
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content="GPS Tracker App" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Cal+Sans:wght@600&display=swap"
        />
    </head>
    <body>
        <AuthProvider client:load>
            <ProtectedRoute client:load>
                <div class="app-shell">
                    <Sidebar
                        locale={locale}
                        translation={translation}
                        active={active}
                        user={user}
                        showAdmin={showAdmin}
                    />
                    <main class="app-shell__main">
                        <!-- Toolbar -->
                        <Toolbar locale={locale} />
                        <!-- Content -->
                        <slot />
                    </main>
                    <!-- Tab Bar (for mobile) -->
                    <TabBar
                        locale={locale}
                        translation={translation}
                        active={active}
                        showAdmin={showAdmin}
                    />
                </div>
            </ProtectedRoute>
        </AuthProvider>
        <script is:inline>
            (function () {
                var stored = localStorage.getItem('theme');
                var preferred = stored
                    ? stored
                    : window.matchMedia('(prefers-color-scheme: dark)').matches
                      ? 'dark'
                      : 'light';
                document.documentElement.dataset.theme = preferred;
            })();
            (function () {
                var stored = localStorage.getItem('language');
                var lang = stored === 'es' || stored === 'en'
                    ? stored
                    : navigator.language.toLowerCase().startsWith('es')
                      ? 'es'
                      : 'en';
                document.documentElement.dataset.language = lang;
            })();
        </script>
    </body>
</html>
