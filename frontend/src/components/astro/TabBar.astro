---
import '@/styles/layout/tabbar.css';
//-- Types
import type { Translation } from '@/i18n';
import type { Language } from '@/types';
import type { SidebarNavItemType } from '@/types/layout';
//-- Components
import { LayoutDashboard, Cpu, ShieldCheck, User } from '@lucide/astro';

/**
 * @interface Props
 * @property {Language} locale - Current locale code ('en' | 'es').
 * @property {Translation} translation - Translation bundle (en/es) used for nav labels.
 * @property {SidebarNavItemType} active - Active nav item, drives the .active highlight and aria-current.
 * @property {boolean} [showAdmin] - Whether to surface the Admin nav item (super_admin only).
 */
interface Props {
    locale: Language;
    translation: Translation;
    active: SidebarNavItemType;
    showAdmin?: boolean;
}

const { locale, translation, active, showAdmin = false } = Astro.props;
const items: Array<{
    key: SidebarNavItemType;
    href: string;
    label: string;
    Icon: typeof LayoutDashboard;
}> = [
    {
        key: 'dashboard',
        href: `/${locale}/`,
        label: translation.nav.dashboard,
        Icon: LayoutDashboard,
    },
    {
        key: 'devices',
        href: `/${locale}/devices/`,
        label: translation.nav.devices,
        Icon: Cpu,
    },
];
if (showAdmin) {
    items.push({
        key: 'admin',
        href: `/${locale}/admin/`,
        label: translation.nav.admin,
        Icon: ShieldCheck,
    });
}
items.push({
    key: 'profile',
    href: `/${locale}/profile`,
    label: translation.nav.profile,
    Icon: User,
});
---

<nav class="tabbar" aria-label={translation.layout.primaryNavMobile}>
    {
        items.map(({ key, href, label, Icon }) => (
            <a
                href={href}
                class:list={['tabbar__item', { 'is-active': active === key }]}
                aria-current={active === key ? 'page' : undefined}
                aria-label={label}
            >
                <Icon size={20} stroke-width={1.75} />
                <span>{label}</span>
            </a>
        ))
    }
</nav>
