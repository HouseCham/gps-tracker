---
import type { Translation } from '@/i18n';
import { User } from '@lucide/astro';
import { NavbarOption } from '@/components/react/ui';
/**
 * @interface Props
 * @property {Translation['header']} seo - The header section of the translation object, containing localized strings for the header component, such as the title and navigation items.
 * @property {Object} user - An object representing the current user, containing their name and role, which can be displayed in the sidebar for personalization and access control purposes.
 */
interface Props {
    headerData: Translation['header'];
    user: {
        name: string;
        role: string;
    };
}
const { headerData, user } = Astro.props;
---

<aside class="dash-sidebar">
    <!-- Logo & Brand -->
    <div class="dash-side-top">
        <span class="brand-mark"><svg><use href="#i-map-pin"></use></svg></span>
        <span class="brand-name">{headerData.title}</span>
    </div>
    <!-- General Navigation -->
    <div class="nav-section">
        <div class="nav-section-label">{headerData.navbar.general.label}</div>
        {
            headerData.navbar.general.options.map(navItem => (
                <NavbarOption
                    label={navItem.label}
                    dataI18n={navItem.dataI18n}
                    href={navItem.href}
                />
            ))
        }
    </div>
    <!-- Admin Navigation -->
    <div class="nav-section">
        <div class="nav-section-label">{headerData.navbar.admin.label}</div>
        {
            headerData.navbar.admin.options.map(navItem => (
                <NavbarOption
                    label={navItem.label}
                    dataI18n={navItem.dataI18n}
                    href={navItem.href}
                />
            ))
        }
    </div>
    <!-- User Profile -->
    <div class="dash-user-card">
        <div class="avatar">
            <User
                width={14}
                height={14}
                stroke={'currentColor'}
                stroke-width={1.75}
            />
        </div>
        <div class="user-info">
            <div class="user-name">{user.name}</div>
            <div class="user-role">{user.role}</div>
        </div>
    </div>
</aside>
