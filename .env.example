# =============================================================================
# GPS-tracker — Environment variables (dev)
# =============================================================================

# ---- Postgres (db service from docker-compose) ----
POSTGRES_USER=gps_user
POSTGRES_PASSWORD=gps_pass
POSTGRES_DB=gps_tracker
POSTGRES_PORT=5432

# ---- API (api service from docker-compose) ----
API_PORT=8080

# ---- JWT (better-auth in frontend) ----
# Point to the frontend Astro (or wherever better-auth is emitting the JWKS).
# Used in the `api` service to validate incoming tokens.
JWT_JWKS_URL=http://localhost:3000/.well-known/jwks.json
JWT_ISSUER=http://localhost:3000
JWT_AUDIENCE=gps-tracker-api
