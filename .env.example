# =============================================================================
# GPS-tracker — Environment variables (dev)
# =============================================================================
# The full stack runs behind a single nginx reverse proxy on https://localhost.
# Everything (frontend, API, Authula) shares the same origin so http-only
# session cookies work without a cross-origin dance.
# =============================================================================

# ---- Postgres (db service from docker-compose) ----
POSTGRES_USER=gps_user
POSTGRES_PASSWORD=gps_pass
POSTGRES_DB=gps_tracker
POSTGRES_PORT=5432

# ---- Nginx reverse proxy (public entry point) ----
NGINX_PORT=443
NGINX_HTTP_PORT=80

# ---- API (api service, internal-only — reached via nginx) ----
# Leave CORS_ALLOWED_ORIGINS empty in local dev (same-origin via nginx).
# Set it in production when frontend and API are deployed separately.
CORS_ALLOWED_ORIGINS=

# ---- Authula (embedded in the api service) ----
# Base URL must match the public origin of the app. Authula uses it to
# build OAuth redirect URIs and email links.
AUTHULA_BASE_URL=https://localhost
AUTHULA_SECRET=replace-with-openssl-rand-hex-32

# ---- Google OAuth (optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- JWT validation (api service validates tokens issued by Authula) ----
# Authula exposes JWKS at <AUTHULA_BASE_URL>/api/auth/.well-known/jwks.json
JWT_JWKS_URL=https://localhost/api/auth/.well-known/jwks.json
JWT_ISSUER=https://localhost
JWT_AUDIENCE=gps-tracker-api

# ---- Frontend (public_api_url is baked into the bundle at build time) ----
PUBLIC_API_URL=https://localhost/api/v1